# ========================
# AI Flood Early Warning System - Configuration (.env)
# Copy to .env and fill with your values
# ========================

# ============ API Configuration ============
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=False
API_WORKERS=4

# ============ Data Paths ============
DATA_DIR=./data
MODELS_DIR=./models
LOGS_DIR=./logs

# ============ Monitoring Configuration ============
# Monitor cycle interval in seconds
MONITOR_INTERVAL=300  # 5 minutes

# ============ Weather API Configuration ============
# Open-Meteo API (free, no key needed)
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast
WEATHER_LATITUDE=15.8
WEATHER_LONGITUDE=78.5

# ============ Telegram Bot Configuration (Optional) ============
# Leave empty to disable Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============ Twilio SMS Configuration (Optional) ============
# Leave empty to disable SMS alerts
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_FROM=
TWILIO_PHONE_TO=

# ============ Logging Configuration ============
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=logs/flood_system.log

# ============ Alert Thresholds ============
# Rainfall threshold (mm) to trigger alert
RAINFALL_ALERT_THRESHOLD_MM=100
# River water level danger threshold (%)
RIVER_DANGER_THRESHOLD_PERCENT=90

# ============ Database Configuration (Future) ============
DB_HOST=localhost
DB_PORT=5432
DB_NAME=flood_prediction_system
DB_USER=flood_user
DB_PASSWORD=

# ============ Feature Flags ============
ENABLE_TELEGRAM_ALERTS=False
ENABLE_SMS_ALERTS=False
ENABLE_CONSOLE_ALERTS=True
ENABLE_EMAIL_ALERTS=False

# ============ Model Configuration ============
AI_MODEL_PATH=models/flood_xgb_model.pkl
SCALER_PATH=models/scaler.pkl
TRADITIONAL_MODEL_PATH=models/flood_model.pkl

# ============ Geographic Configuration ============
REGION=Karnataka
COUNTRY=India
TIMEZONE=Asia/Kolkata
